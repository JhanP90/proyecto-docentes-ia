# backend/.env.example
# ─── Copia este archivo como .env en esta misma carpeta y completa los valores ───

# 1. Base de datos (Por defecto SQLite, ideal para probar en local sin instalar nada extra)
DATABASE_URL=sqlite:///./sql_app.db

# Si prefieres usar PostgreSQL, comenta la línea de arriba y usa esta:
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/evaluacion_docente

# 2. Seguridad
# Seguridad JWT — genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERA_UN_SECRETO_FUERTE_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 3. Inteligencia Artificial (Google Gemini)
# Debes poner aquí tu propia API Key de Google AI Studio (es gratis)
GEMINI_API_KEY=TU_CLAVE_DE_API_DE_GOOGLE_AI_STUDIO
GEMINI_MODEL=gemini-2.5-flash

# 4. Configuración de Archivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# 5. CORS (Permite que el frontend se comunique con el backend)
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
